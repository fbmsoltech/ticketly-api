APP_NAME=Ticketly API
APP_VERSION=0.1.0
APP_ENV=local

DATABASE_URL=postgresql+psycopg://ticketly_user:ticketly_user@db:5432/ticketly_db
TEST_DATABASE_URL=postgresql+psycopg://ticketly_user:ticketly_user@test-db:5432/ticketly_test_db

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

LOG_LEVEL=INFO
ENABLE_REQUEST_LOGGING=true
ENABLE_METRICS=true

# Initial seed examples. Do not use these values as production secrets.
CREATE_INITIAL_ADMIN=false
INITIAL_ADMIN_NAME=Admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me

# Production example for Render.
# Replace JWT_SECRET_KEY with a strong secret configured in Render.
# DATABASE_URL must come from the managed Render PostgreSQL database.
#
# APP_NAME=Ticketly API
# APP_VERSION=0.1.0
# APP_ENV=production
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/database
# JWT_SECRET_KEY=change-me-in-production
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
# LOG_LEVEL=INFO
# ENABLE_REQUEST_LOGGING=true
# ENABLE_METRICS=true
